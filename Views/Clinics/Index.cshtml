@model IEnumerable<MediQueue.Models.Clinic>
@{
    ViewData["Title"] = "العيادات";
}

<div class="container fade-in" style="padding-top: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <h1 class="section-title" style="margin: 0;">إدارة العيادات</h1>
        <a asp-action="Create" class="btn btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-inline-end: 0.5rem;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            إضافة عيادة جديدة
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card" style="text-align: center; padding: 4rem 2rem;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--text-muted); margin-bottom:1rem">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
            </svg>
            <h3 style="color:var(--text-secondary); margin-bottom: 0.5rem">لا توجد عيادات</h3>
            <p style="color:var(--text-muted); margin-bottom: 1.5rem;">لم تقم بإضافة أي عيادات حتى الآن.</p>
            <a asp-action="Create" class="btn btn-primary">إضافة عيادة</a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 80px; text-align: center;">الرقم</th>
                        <th>اسم العيادة</th>
                        <th>العنوان</th>
                        <th style="text-align: center;">رقم الهاتف</th>
                        <th style="text-align: center;">عدد الأطباء</th>
                        <th style="text-align: center; width: 220px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var clinic in Model)
                    {
                        <tr>
                            <td style="text-align: center; font-weight: 700; color: var(--text-muted);">#@clinic.ClinicID</td>
                            <td>
                                <span style="font-weight: 700; color: var(--text-primary);">@clinic.Name</span>
                            </td>
                            <td>
                                <span style="color: var(--text-secondary); font-size: 0.9rem;">@clinic.Address</span>
                            </td>
                            <td style="text-align: center;" dir="ltr">
                                @clinic.PhoneNumber
                            </td>
                            <td style="text-align: center;">
                                <span class="status-badge status-progress" style="font-size: 0.85rem; padding: 0.15rem 0.6rem;">
                                    @(clinic.Doctors?.Count() ?? 0) طبيب
                                </span>
                            </td>
                            <td>
                                <div class="table-actions" style="justify-content: center;">
                                    <a asp-action="Details" asp-route-id="@clinic.ClinicID" class="btn btn-sm btn-outline" title="التفاصيل">
                                        عرض
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@clinic.ClinicID" class="btn btn-sm btn-outline" style="color: var(--accent); border-color: color-mix(in srgb, var(--accent) 30%, transparent);" title="تعديل">
                                        تعديل
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@clinic.ClinicID" class="btn btn-sm btn-danger-outline" title="حذف">
                                        حذف
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
