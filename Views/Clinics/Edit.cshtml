@model MediQueue.ViewModel.ClinicVM
@{
    ViewData["Title"] = "تعديل العيادة";
}

<div class="container fade-in" style="max-width: 600px; padding-top: 2rem;">
    <div class="card">
        <h1 class="section-title" style="margin-top: 0; text-align: center;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-inline-end: 0.5rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            تعديل العيادة
        </h1>
        <hr style="border: none; border-top: 1px solid var(--border); margin-block: 1rem 1.5rem;" />

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert">
                <strong>الرجاء تصحيح الأخطاء التالية:</strong>
            </div>

            <input type="hidden" asp-for="ClinicID" />

            <div class="form-group">
                <label asp-for="Name" class="form-label">اسم العيادة</label>
                <input asp-for="Name" class="form-input" placeholder="أدخل اسم العيادة" />
                <span asp-validation-for="Name" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Address" class="form-label">عنوان العيادة</label>
                <input asp-for="Address" class="form-input" placeholder="ادخل عنوان العيادة" />
                <span asp-validation-for="Address" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhoneNumber" class="form-label">رقم الهاتف</label>
                <input asp-for="PhoneNumber" class="form-input" placeholder="ادخل رقم الهاتف" dir="ltr" />
                <span asp-validation-for="PhoneNumber" class="form-error"></span>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">
                    تحديث العيادة
                </button>
                <a asp-action="Index" class="btn btn-outline" style="flex: 1;">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
