@model MediQueue.Models.Clinic
@{
    ViewData["Title"] = "حذف العيادة";
}

<div class="container fade-in" style="max-width: 600px; padding-top: 2rem;">
    <div class="card" style="border-top: 4px solid var(--danger);">
        <h1 class="section-title" style="margin-top: 0; color: var(--danger); text-align: center;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-inline-end: 0.5rem;"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
            حذف العيادة
        </h1>
        
        <div class="alert alert-danger" style="margin-block: 1.5rem;">
            <strong>تحذير!</strong> هل أنت متأكد أنك تريد حذف هذه العيادة؟ هذا الإجراء لا يمكن التراجع عنه.
        </div>

        <div style="background: color-mix(in srgb, var(--background) 50%, var(--surface)); padding: 1.5rem; border-radius: var(--radius); border: 1px solid var(--border); margin-bottom: 2rem;">
            <div style="display: grid; grid-template-columns: 100px 1fr; gap: 1rem; margin-bottom: 1rem;">
                <span class="text-secondary fw-bold">الرقم:</span>
                <span>@Model.ClinicID</span>
            </div>
            <div style="display: grid; grid-template-columns: 100px 1fr; gap: 1rem; margin-bottom: 1rem;">
                <span class="text-secondary fw-bold">الاسم:</span>
                <span style="font-weight: 700;">@Model.Name</span>
            </div>
            <div style="display: grid; grid-template-columns: 100px 1fr; gap: 1rem; margin-bottom: 1rem;">
                <span class="text-secondary fw-bold">العنوان:</span>
                <span>@Model.Address</span>
            </div>
            <div style="display: grid; grid-template-columns: 100px 1fr; gap: 1rem;">
                <span class="text-secondary fw-bold">الهاتف:</span>
                <span dir="ltr" style="text-align: end;">@Model.PhoneNumber</span>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="ClinicID" />
            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn btn-danger-outline" style="flex: 1; background: var(--danger); color: white; border-color: var(--danger);">
                    تأكيد الحذف
                </button>
                <a asp-action="Index" class="btn btn-outline" style="flex: 1;">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>
