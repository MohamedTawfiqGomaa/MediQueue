@model IEnumerable<MediQueue.Models.Appointment>
@{
    ViewData["Title"] = "مواعيدي";
}

<style>
    .appointments-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1.5rem;
        margin-top: 1.5rem;
    }

    .apt-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

        .apt-card:hover {
            box-shadow: var(--shadow);
            transform: translateY(-2px);
        }

    .apt-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 1px solid var(--border);
        padding-bottom: 1rem;
    }

    .doctor-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .doctor-img {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--border);
    }

    .apt-details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        font-size: 0.9rem;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
    }

    .detail-label {
        color: var(--text-muted);
        font-size: 0.8rem;
    }

    .detail-value {
        font-weight: 700;
        color: var(--text-primary);
    }

    .apt-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: auto;
        padding-top: 1rem;
    }

    .status-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .status-booked {
        background: rgba(79, 70, 229, 0.1);
        color: #4f46e5;
    }

    .status-completed {
        background: rgba(16, 185, 129, 0.1);
        color: #059669;
    }

    .status-cancelled {
        background: rgba(239, 68, 68, 0.1);
        color: #dc2626;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-block: 2rem 1rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }

    .empty-state svg {
        color: var(--text-muted);
        margin-bottom: 1rem;
    }

    @@media (max-width: 600px) {
        .appointments-grid {
            grid-template-columns: 1fr;
        }

        .apt-details {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container fade-in">
    <div class="page-header">
        <h1 class="page-hero-title" style="margin: 0;">سجل الحجوزات</h1>
        <a href="/" class="btn btn-primary">حجز موعد جديد</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <h3 style="color:var(--text-secondary); margin-bottom: 0.5rem">لا توجد حجوزات سابقة</h3>
            <p style="color:var(--text-muted)">لم تقم بحجز أي مواعيد حتى الآن.</p>
        </div>
    }
    else
    {
        <div class="appointments-grid">
            @foreach (var apt in Model.OrderByDescending(a => a.AppointmentDate).ThenByDescending(a => a.AppointmentTime))
            {
                <div class="apt-card">
                    <div class="apt-header">
                        <div class="doctor-info">
                            <img src="@(apt.Doctor?.ProfileImagePath ?? "/images/default-doctor.png")"
                                 alt="@apt.Doctor?.FullName"
                                 class="doctor-img"
                                 onerror="this.src='https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(apt.Doctor?.FullName ?? "Dr"))&background=4f46e5&color=fff&size=100'" />
                            <div>
                                <h4 style="margin:0; font-size: 1.05rem;">@apt.Doctor?.FullName</h4>
                                <span style="font-size: 0.85rem; color: var(--text-secondary);">@apt.Doctor?.Specialty</span>
                            </div>
                        </div>
                        <div>
                            @if (apt.Status == MediQueue.Models.AppointmentStatus.Booked)
                            {
                                <span class="status-badge status-booked">قادم</span>
                            }
                            else if (apt.Status == MediQueue.Models.AppointmentStatus.Completed)
                            {
                                <span class="status-badge status-completed">مكتمل</span>
                            }
                            else
                            {
                                <span class="status-badge status-cancelled">ملغي</span>
                            }
                        </div>
                    </div>

                    <div class="apt-details">
                        <div class="detail-item">
                            <span class="detail-label">التاريخ</span>
                            <span class="detail-value">@apt.AppointmentDate.ToString("yyyy-MM-dd")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">الوقت</span>
                            <span class="detail-value">@apt.AppointmentTime.ToString(@"hh\:mm")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">اسم المريض</span>
                            <span class="detail-value">@apt.Patient?.FullName</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">رقم الحجز</span>
                            <span class="detail-value">#@apt.AppointmentID</span>
                        </div>
                    </div>

                    <div class="apt-actions">
                        @if (apt.Status == MediQueue.Models.AppointmentStatus.Booked)
                        {
                            <a href="@Url.Action("Track", "Appointments", new { id = apt.AppointmentID })"
                               class="btn btn-primary" style="flex: 1">
                                تتبع الطابور
                            </a>

                            <form asp-action="Cancel" method="post" style="flex: 1">
                                <input type="hidden" name="id" value="@apt.AppointmentID" />
                                <button type="submit"
                                        class="btn btn-danger-outline btn-block"
                                        onclick="return confirm('هل أنت متأكد من الإلغاء؟')">
                                    إلغاء
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
