@model MediQueue.ViewModel.AvailableSlotViewModel

@{
    ViewData["Title"] = "تعديل الموعد المتاح";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>تعديل الموعد المتاح</h1>
            <hr />

            @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
            {
                <div class="alert alert-danger">
                    <h5>أخطاء في النموذج:</h5>
                    <ul>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="EditAvailableSlot" method="post" class="needs-validation">
                <input type="hidden" asp-for="SlotID" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Date" class="form-label">التاريخ *</label>
                        <input asp-for="Date" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")"  required />
                        <span asp-validation-for="Date" class="text-danger d-block mt-1"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="StartTime" class="form-label">وقت البداية *</label>
                        <input asp-for="StartTime" type="time" class="form-control" required />
                        <span asp-validation-for="StartTime" class="text-danger d-block mt-1"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="EndTime" class="form-label">وقت النهاية *</label>
                        <input asp-for="EndTime" type="time" class="form-control" required />
                        <span asp-validation-for="EndTime" class="text-danger d-block mt-1"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="MaxPatients" class="form-label">الحد الأقصى للمرضى *</label>
                        <input asp-for="MaxPatients" type="number" class="form-control" min="1" max="50" required />
                        <small class="form-text text-muted d-block mt-1">يجب أن يكون بين 1 و 50</small>
                        <span asp-validation-for="MaxPatients" class="text-danger d-block mt-1"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-12">
                        <div class="alert alert-info">
                            <strong>إحصائيات الموعد:</strong>
                            <br/>
                            الحجوزات الحالية: <span class="badge bg-primary">@Model.CurrentBookings</span> / @Model.MaxPatients
                            <br/>
                            الأماكن المتاحة: <span class="badge bg-success">@Model.AvailableSlotsCount</span>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> تحديث الموعد
                    </button>
                    <a asp-action="ManageAvailableSlots" class="btn btn-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> إلغاء
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
