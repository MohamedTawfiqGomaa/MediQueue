@model IEnumerable<MediQueue.Models.User>
@{
    ViewData["Title"] = "المستخدمين";
}

<div class="container fade-in" style="padding-top: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <h1 class="section-title" style="margin: 0;">إدارة المستخدمين</h1>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <a asp-action="Doctors" class="btn btn-outline">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-inline-end: 0.5rem;"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                عرض الأطباء فقط
            </a>
            <a asp-action="CreateDoctor" class="btn btn-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-inline-end: 0.5rem;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                إضافة طبيب جديد
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card" style="text-align: center; padding: 4rem 2rem;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--text-muted); margin-bottom:1rem">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            <h3 style="color:var(--text-secondary); margin-bottom: 0.5rem">لا يوجد مستخدمين</h3>
            <p style="color:var(--text-muted); margin-bottom: 1.5rem;">لم تقم بإضافة أي مستخدمين حتى الآن.</p>
            <a asp-action="CreateDoctor" class="btn btn-primary">إضافة طبيب جديد</a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 100px; text-align: center;">بطاقة تعريف</th>
                        <th>الاسم الكامل</th>
                        <th>البريد الإلكتروني</th>
                        <th style="text-align: center;">رقم الهاتف</th>
                        <th style="text-align: center;">التخصص</th>
                        <th style="text-align: center;">العيادة</th>
                        <th style="text-align: center; width: 220px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td style="text-align: center; font-family: monospace; color: var(--text-muted); font-size: 0.85rem;">
                                @user.Id.Substring(0, Math.Min(8, user.Id.Length))
                            </td>
                            <td>
                                <span style="font-weight: 700; color: var(--text-primary);">@user.FullName</span>
                            </td>
                            <td>
                                <span style="color: var(--text-secondary); font-size: 0.9rem;" dir="ltr">@user.Email</span>
                            </td>
                            <td style="text-align: center;" dir="ltr">
                                @user.PhoneNumber
                            </td>
                            <td style="text-align: center;">
                                @if (!string.IsNullOrEmpty(user.Specialty))
                                {
                                    <span class="status-badge status-progress">@user.Specialty</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td style="text-align: center;">
                                @if (user.Clinic != null)
                                {
                                    <span class="status-badge status-completed">@user.Clinic.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <div class="table-actions" style="justify-content: center;">
                                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline" title="التفاصيل">عرض</a>
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline" style="color: var(--accent); border-color: color-mix(in srgb, var(--accent) 30%, transparent);" title="تعديل">تعديل</a>
                                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger-outline" title="حذف">حذف</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
