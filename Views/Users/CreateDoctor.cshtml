@model MediQueue.ViewModel.AddDoctorViewModel

@{
    ViewData["Title"] = "إنشاء طبيب جديد";
    var clinics = ViewData["Clinics"] as IEnumerable<MediQueue.Models.Clinic> ?? new List<MediQueue.Models.Clinic>();
}

<div class="container fade-in" style="max-width: 800px; padding-top: 2rem;">
    <div class="card">
        <h1 class="section-title" style="margin-top: 0; text-align: center;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-inline-end: 0.5rem;"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            إنشاء طبيب جديد
        </h1>
        <hr style="border: none; border-top: 1px solid var(--border); margin-block: 1rem 1.5rem;" />

        <form asp-action="CreateDoctor" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="grid grid-cols-2" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
                <div class="form-group mb-0">
                    <label asp-for="FullName" class="form-label">الاسم الكامل</label>
                    <input asp-for="FullName" class="form-input" placeholder="أدخل الاسم الكامل" />
                    <span asp-validation-for="FullName" class="form-error"></span>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
                    <input asp-for="Email" type="email" class="form-input" placeholder="أدخل البريد الإلكتروني" dir="ltr" />
                    <span asp-validation-for="Email" class="form-error"></span>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="PhoneNumber" class="form-label">رقم الهاتف</label>
                    <input asp-for="PhoneNumber" type="tel" class="form-input" placeholder="أدخل رقم الهاتف" dir="ltr" />
                    <span asp-validation-for="PhoneNumber" class="form-error"></span>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="Specialty" class="form-label">التخصص</label>
                    <input asp-for="Specialty" class="form-input" placeholder="أدخل التخصص، مثل: قلب، جلدية" />
                    <span asp-validation-for="Specialty" class="form-error"></span>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="ClinicID" class="form-label">العيادة</label>
                    <select asp-for="ClinicID" class="form-input" asp-items="@(new SelectList(clinics, "ClinicID", "Name"))">
                        <option value="">-- اختر العيادة --</option>
                    </select>
                    <span asp-validation-for="ClinicID" class="form-error"></span>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="ProfileImage" class="form-label">صورة الطبيب</label>
                    <input asp-for="ProfileImage" type="file" class="form-input" accept="image/*" style="padding: 0.5rem 1rem;" />
                    <div class="text-muted" style="font-size: 0.8rem; margin-top: 0.25rem;">مدعوم: jpg، png، gif. الحد الأقصى للحجم: 5MB</div>
                    <span asp-validation-for="ProfileImage" class="form-error"></span>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="Password" class="form-label">كلمة المرور</label>
                    <input asp-for="Password" type="password" class="form-input" placeholder="أدخل كلمة المرور" />
                    <span asp-validation-for="Password" class="form-error"></span>
                </div>

                <div class="form-group mb-0">
                    <label asp-for="ConfirmPassword" class="form-label">تأكيد كلمة المرور</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="أدخل تأكيد كلمة المرور" />
                    <span asp-validation-for="ConfirmPassword" class="form-error"></span>
                </div>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2.5rem;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">
                    إنشاء طبيب
                </button>
                <a asp-action="Index" class="btn btn-outline" style="flex: 1;">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
