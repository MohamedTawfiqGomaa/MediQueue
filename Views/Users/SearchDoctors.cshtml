@model IEnumerable<MediQueue.Models.User>

@{
    ViewData["Title"] = "Search Doctors";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Search Results - @ViewData["Specialty"]</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Doctors" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (Model.Count() == 0)
    {
        <div class="alert alert-info">
            No doctors found with specialty "@ViewData["Specialty"]".
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var doctor in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@doctor.FullName</h5>
                            <p class="card-text">
                                <strong>Specialty:</strong> <span class="badge bg-success">@doctor.Specialty</span><br />
                                <strong>Email:</strong> @doctor.Email<br />
                                <strong>Phone:</strong> @doctor.PhoneNumber<br />
                                <strong>Clinic:</strong> @(doctor.Clinic?.Name ?? "Not assigned")
                            </p>
                        </div>
                        <div class="card-footer">
                            <a asp-action="Details" asp-route-id="@doctor.Id" class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i> View
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
