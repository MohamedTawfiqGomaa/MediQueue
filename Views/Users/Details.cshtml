@model MediQueue.Models.User

@{
    ViewData["Title"] = "تفاصيل المستخدم";
}

<div class="container fade-in" style="padding-top: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1 class="section-title" style="margin: 0;">تفاصيل المستخدم</h1>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">تعديل</a>
            <a asp-action="Index" class="btn btn-outline">الرجوع للقائمة</a>
        </div>
    </div>

    <div class="grid grid-cols-4" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
        <div class="card" style="grid-column: span 1;">
            <div style="text-align: center; margin-bottom: 1.5rem;">
                <img src="@(Model.ProfileImagePath ?? "/images/default-doctor.png")" 
                     alt="@Model.FullName" 
                     style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid var(--border); margin: 0 auto 1rem;"
                     onerror="this.src='https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(Model.FullName ?? "U"))&background=4f46e5&color=fff&size=200'" />
                <h2 style="font-size: 1.25rem; margin: 0;">@Model.FullName</h2>
                @if (!string.IsNullOrEmpty(Model.Specialty))
                {
                    <div style="color: var(--primary); font-weight: 700; font-size: 0.9rem; margin-top: 0.25rem;">@Model.Specialty</div>
                }
            </div>
            
            <hr style="border: none; border-top: 1px solid var(--border); margin-block: 1.5rem;" />

            <div style="margin-bottom: 1.25rem;">
                <div class="text-secondary" style="font-size: 0.85rem; margin-bottom: 0.25rem;">رقم المستخدم</div>
                <div style="font-family: monospace; font-size: 0.9rem; word-break: break-all;">@Model.Id</div>
            </div>
            
            <div style="margin-bottom: 1.25rem;">
                <div class="text-secondary" style="font-size: 0.85rem; margin-bottom: 0.25rem;">اسم المستخدم</div>
                <div style="font-weight: 600;">@Model.UserName</div>
            </div>
        </div>

        <div class="card" style="grid-column: span 2;">
            <h3 style="margin-bottom: 1.5rem; font-size: 1.1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.75rem;">معلومات الاتصال والعمل</h3>
            
            <div class="grid grid-cols-2" style="gap: 1.5rem;">
                <div>
                    <div class="text-secondary" style="font-size: 0.85rem; margin-bottom: 0.25rem;">البريد الإلكتروني</div>
                    <div style="font-weight: 600; font-size: 1.05rem;" dir="ltr" align="right">@Model.Email</div>
                </div>

                <div>
                    <div class="text-secondary" style="font-size: 0.85rem; margin-bottom: 0.25rem;">رقم الهاتف</div>
                    <div style="font-weight: 600; font-size: 1.05rem;" dir="ltr" align="right">@Model.PhoneNumber</div>
                </div>

                <div>
                    <div class="text-secondary" style="font-size: 0.85rem; margin-bottom: 0.25rem;">العيادة</div>
                    <div>
                        @if (Model.Clinic != null)
                        {
                            <a asp-controller="Clinics" asp-action="Details" asp-route-id="@Model.Clinic.ClinicID" class="status-badge status-completed" style="text-decoration: none;">
                                @Model.Clinic.Name
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">غير مسجل في عيادة</span>
                        }
                    </div>
                </div>

                <div>
                    <div class="text-secondary" style="font-size: 0.85rem; margin-bottom: 0.25rem;">التخصص</div>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.Specialty))
                        {
                            <span class="status-badge status-progress">@Model.Specialty</span>
                        }
                        else
                        {
                            <span class="text-muted">غير محدد</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
