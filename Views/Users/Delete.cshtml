@model MediQueue.Models.User

@{
    ViewData["Title"] = "حذف المستخدم";
}

<div class="container fade-in" style="max-width: 600px; padding-top: 2rem;">
    <div class="card" style="border-top: 4px solid var(--danger);">
        <h1 class="section-title" style="margin-top: 0; color: var(--danger); text-align: center;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-inline-end: 0.5rem;"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="11" x2="23" y2="11"/><line x1="21" y1="9" x2="21" y2="13"/></svg>
            حذف المستخدم
        </h1>
        
        <div class="alert alert-danger" style="margin-block: 1.5rem;">
            <strong>تحذير!</strong> هل أنت متأكد أنك تريد حذف هذا المستخدم؟ هذا الإجراء لا يمكن التراجع عنه.
        </div>

        <div style="background: color-mix(in srgb, var(--background) 50%, var(--surface)); padding: 1.5rem; border-radius: var(--radius); border: 1px solid var(--border); margin-bottom: 2rem;">
            <div style="display: grid; grid-template-columns: 120px 1fr; gap: 1rem; margin-bottom: 1rem;">
                <span class="text-secondary fw-bold">رقم المستخدم:</span>
                <span style="font-family: monospace; font-size: 0.9rem; word-break: break-all;">@Model.Id</span>
            </div>
            <div style="display: grid; grid-template-columns: 120px 1fr; gap: 1rem; margin-bottom: 1rem;">
                <span class="text-secondary fw-bold">الاسم:</span>
                <span style="font-weight: 700;">@Model.FullName</span>
            </div>
            <div style="display: grid; grid-template-columns: 120px 1fr; gap: 1rem; margin-bottom: 1rem;">
                <span class="text-secondary fw-bold">البريد الإلكتروني:</span>
                <span dir="ltr" style="text-align: right;">@Model.Email</span>
            </div>
            <div style="display: grid; grid-template-columns: 120px 1fr; gap: 1rem;">
                <span class="text-secondary fw-bold">الهاتف:</span>
                <span dir="ltr" style="text-align: right;">@Model.PhoneNumber</span>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn btn-danger-outline" style="flex: 1; background: var(--danger); color: white; border-color: var(--danger);">
                    تأكيد الحذف
                </button>
                <a asp-action="Index" class="btn btn-outline" style="flex: 1;">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>
